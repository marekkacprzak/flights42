{
  "name": "flights42",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "ai-server": "mastra dev --dir ai-server/src/mastra",
    "ai-server:build": "mastra build --dir ai-server/src/mastra",
    "ai-server:start": "mastra start --dir ai-server/src/mastra",
    "agent": "npm run ai-server",
    "agent:build": "npm run ai-server:build",
    "agent:start": "npm run ai-server:start",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write \"**/*.{ts,html,scss,css,json,md}\"",
    "ag-ui-demo:server": "node --import tsx ag-ui-demo/server/index.ts",
    "ag-ui-demo:client": "node --import tsx ag-ui-demo/client/index.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "prettier": {
    "bracketSameLine": true,
    "printWidth": 80,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@a2ui/angular": "^0.9.1",
    "@a2ui/web_core": "^0.9.2",
    "@ag-ui/client": "^0.0.52",
    "@ag-ui/core": "^0.0.52",
    "@ag-ui/mastra": "1.0.0",
    "@ag-ui/mcp-apps-middleware": "^0.0.3",
    "@ai-sdk/openai": "^3.0.49",
    "@angular-architects/native-federation": "^21.1.0",
    "@angular-architects/ngrx-toolkit": "^21.0.1",
    "@angular/animations": "^21.2.1",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/material": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/router": "^21.2.1",
    "@copilotkit/runtime": "^1.53.0",
    "@hashbrownai/angular": "^0.4.1",
    "@hashbrownai/core": "^0.4.1",
    "@hashbrownai/google": "^0.4.1",
    "@hashbrownai/openai": "^0.4.1",
    "@mastra/client-js": "^1.11.2",
    "@mastra/core": "^1.24.1",
    "@mastra/libsql": "^1.7.3",
    "@mastra/loggers": "^1.0.4",
    "@mastra/mcp": "^1.4.1",
    "@mastra/memory": "^1.13.0",
    "@modelcontextprotocol/ext-apps": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@ngrx/operators": "^21.0.1",
    "@ngrx/signals": "^21.0.1",
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "jsonata": "^2.1.0",
    "marked": "^17.0.1",
    "ngx-markdown": "^21.0.1",
    "quickjs-emscripten": "^0.32.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "@commitlint/config-conventional": "^20.2.0",
    "@softarc/detective": "^2.0.2",
    "@softarc/eslint-plugin-sheriff": "^0.19.6",
    "@softarc/sheriff-core": "^0.19.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "angular-eslint": "21.1.0",
    "commitlint": "^20.2.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "lint-staged": "^16.2.7",
    "mastra": "^1.5.0",
    "ng-packagr": "^21.0.0",
    "playwright": "^1.58.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.47.0",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^4.0.8"
  }
}
