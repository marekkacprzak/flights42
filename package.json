{
  "name": "flights42",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write \"**/*.{ts,html,scss,css,json,md}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "prettier": {
    "bracketSameLine": true,
    "printWidth": 80,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular-architects/native-federation": "^21.1.0",
    "@angular-architects/ngrx-toolkit": "^21.0.1",
    "@angular/animations": "^22.0.0-rc.1",
    "@angular/cdk": "^22.0.0-rc.1",
    "@angular/common": "^22.0.0-rc.1",
    "@angular/compiler": "^22.0.0-rc.1",
    "@angular/core": "^22.0.0-rc.1",
    "@angular/forms": "^22.0.0-rc.1",
    "@angular/material": "^22.0.0-rc.1",
    "@angular/platform-browser": "^22.0.0-rc.1",
    "@angular/router": "^22.0.0-rc.1",
    "@hashbrownai/angular": "^0.4.1",
    "@hashbrownai/core": "^0.4.1",
    "@hashbrownai/google": "^0.4.1",
    "@hashbrownai/openai": "^0.4.1",
    "@ngrx/operators": "^21.0.1",
    "@ngrx/signals": "^21.0.1",
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "marked": "^17.0.1",
    "ngx-markdown": "^21.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.1.0",
    "@angular/build": "^22.0.0-rc.0",
    "@angular/cli": "^22.0.0-rc.0",
    "@angular/compiler-cli": "^22.0.0-rc.1",
    "@commitlint/config-conventional": "^20.2.0",
    "@softarc/detective": "^2.0.2",
    "@softarc/eslint-plugin-sheriff": "^0.19.6",
    "@softarc/sheriff-core": "^0.19.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "angular-eslint": "21.1.0",
    "commitlint": "^20.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "lint-staged": "^16.2.7",
    "ng-packagr": "^22.0.0-rc.0",
    "playwright": "^1.58.0",
    "prettier": "^3.7.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.47.0",
    "vitest": "^4.0.8"
  }
}
